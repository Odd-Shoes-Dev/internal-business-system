# ============================================================
# Business Management Platform - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SIGNUPS_ENABLED=true

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM=YourCompany <noreply@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# ── Whop (Subscription Payments) ─────────────────────────────
WHOP_API_KEY=your_whop_api_key
WHOP_COMPANY_ID=biz_your_whop_company_id
NEXT_PUBLIC_WHOP_COMPANY_ID=biz_your_whop_company_id
WHOP_SETUP_SECRET=your_whop_setup_secret

# ── File Storage (Supabase Storage only — not auth/db) ───────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Cron Jobs ────────────────────────────────────────────────
CRON_SECRET=your_cron_secret

# ── Support Contact (shown in app UI) ────────────────────────
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
NEXT_PUBLIC_DISPLAY_PHONE=+256-XXX-XXXX-XXX
NEXT_PUBLIC_WHATSAPP_LINK=https://wa.me/256123456789

# ── Internal ─────────────────────────────────────────────────
APP_DB_PROVIDER=neon
